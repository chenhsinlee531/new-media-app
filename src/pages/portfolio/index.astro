---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/Shared/PageIntro.astro';

import fs from 'node:fs';
import path from 'node:path';

const contentDir = path.resolve('./src/content/portfolio');
const projects = fs.readdirSync(contentDir)
  .filter(f => f.endsWith('.json'))
  .map(f => ({ default: JSON.parse(fs.readFileSync(path.join(contentDir, f), 'utf8')) }));
---

<BaseLayout title="Work — ChenHsin Lee" description="Design and product case studies.">
  <PageIntro
    label="Portfolio"
    title="Work"
    description={"Two projects, two formats. One in streaming, one on the conference stage.\nBoth ask the same question: what story does this actually need to tell?"}
  />

  <section class="project-list section-pad">
    <div class="container">
      {projects.map(({ default: project }, i) => (
        <article class="project-row reveal" style={`transition-delay: ${i * 120}ms`}>
          <a href={`/portfolio/${project.slug}`} class="project-row-link">
            <div class="project-cover">
              {project.coverImage
                ? <img src={project.coverImage} alt={project.title} class="project-cover-img" />
                : <div class="project-cover-placeholder"><span class="project-cover-title">{project.title}</span></div>
              }
            </div>
            <div class="project-meta">
              <div class="project-meta-top">
                <div class="project-tags">
                  {project.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <span class="project-year label">{project.date}</span>
              </div>
              <h2 class="project-title">{project.title}</h2>
              <p class="project-subtitle">{project.subtitle}</p>
              <span class="project-cta">
                View case study <span class="cta-arrow">→</span>
              </span>
            </div>
          </a>
          {i < projects.length - 1 && <hr class="project-divider" />}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .project-list { background: var(--color-bg); }

  .project-row {
    margin-bottom: var(--space-6);
  }

  .project-row-link {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    transition: opacity var(--duration-fast);
  }

  .project-row-link:hover { opacity: 0.85; }

  @media (min-width: 768px) {
    .project-row-link {
      grid-template-columns: 480px 1fr;
      gap: var(--space-6);
      align-items: center;
    }
  }

  .project-cover {
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16/10;
    background: var(--color-bg-card);
  }

  .project-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-bg-card) 0%, var(--color-border) 100%);
  }

  .project-cover-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-style: italic;
    color: rgba(26,26,24,0.12);
    text-align: center;
    padding: var(--space-2);
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .project-meta-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .project-year { 
    color: var(--color-text-muted); 
  
  }

  .project-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .project-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 48ch;
  }

  .project-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    margin-top: var(--space-2);
    transition: gap var(--duration-fast) var(--ease-out);
  }

  .project-row-link:hover .project-cta { gap: 12px; }
  .project-row-link:hover .cta-arrow { color: var(--color-accent); }

  .cta-arrow { transition: color var(--duration-fast); }

  .project-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-6);
    margin-bottom: var(--space-6);
  }
</style>
