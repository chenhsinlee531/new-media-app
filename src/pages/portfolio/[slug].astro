---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/Portfolio/SectionHeader.astro';
import MediaBlock from '../../components/Portfolio/MediaBlock.astro';
import PullQuote from '../../components/Portfolio/PullQuote.astro';
import StatRow from '../../components/Portfolio/StatRow.astro';
import TestimonialStrip from '../../components/Portfolio/TestimonialStrip.astro';
import LogoStrip from '../../components/Portfolio/LogoStrip.astro';

import fs from 'node:fs';
import path from 'node:path';

const { slug } = Astro.params;
const contentDir = path.resolve('./src/content/portfolio');
const files = fs.readdirSync(contentDir).filter(f => f.endsWith('.json'));
const all = files.map(f => JSON.parse(fs.readFileSync(path.join(contentDir, f), 'utf8')));
const project = all.find(p => p.slug === slug);

if (!project) return Astro.redirect('/portfolio');

// Build scroll nav items
const navItems: { id: string; label: string }[] = [];
project.sections.forEach((section: any) => {
  navItems.push({ id: `section-${section.number}`, label: `${section.number} ${section.heading}` });
  if (section.blocks) {
    section.blocks.forEach((block: any) => {
      if (block.showInNav && block.heading) {
        const id = `block-${block.heading.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
        navItems.push({ id, label: block.heading });
      }
    });
  }
});
---

<BaseLayout title={`${project.title} — ChenHsin Lee`} description={project.subtitle}>
  <!-- Scroll nav -->
  <nav class="scroll-nav" aria-label="Page sections">
    <div class="scroll-nav-line"></div>
    {navItems.map((item) => (
      <a href={`#${item.id}`} class="scroll-nav-dot" data-nav-id={item.id} aria-label={item.label}>
        <span class="scroll-nav-block"></span>
      </a>
    ))}
  </nav>
  <!-- Case Study Header -->
  <header class="cs-header">
    <div class="cs-header-inner">
      <a href="/portfolio" class="back-link label">← Work</a>
      <div class="cs-meta">
        {project.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        <span class="cs-date label">{project.date}</span>
      </div>
      <h1 class="cs-title reveal">{project.title}</h1>
      <p class="cs-subtitle reveal reveal-delay-1">{project.subtitle}</p>
      {(project.role || project.venue || project.markets) && (
        <div class="cs-details reveal reveal-delay-2">
          {project.role && (
            <div class="cs-detail">
              <span class="cs-detail-label label">Role</span>
              <span class="cs-detail-value">{project.role}</span>
            </div>
          )}
          {project.venue && (
            <div class="cs-detail">
              <span class="cs-detail-label label">Venue</span>
              <span class="cs-detail-value">{project.venue}</span>
            </div>
          )}
          {project.markets && (
            <div class="cs-detail">
              <span class="cs-detail-label label">Markets</span>
              <span class="cs-detail-value">{project.markets}</span>
            </div>
          )}
        </div>
      )}
    </div>

    {project.coverImage && (
      <div class="cs-cover reveal reveal-delay-2">
        <img src={project.coverImage} alt={project.title} class="cs-cover-img" />
      </div>
    )}
  </header>

  <!-- Logo Strip (optional, defined per-project in JSON) -->
  {project.logoStrip && (
    <LogoStrip
      label={project.logoStrip.label}
      wallImage={project.logoStrip.wallImage}
      logos={project.logoStrip.logos}
    />
  )}

  <!-- Case Study Body Sections -->
  {project.sections.map((section: any) => (
    <section id={`section-${section.number}`} class={`cs-section ${section.variant === 'dark' ? 'dark-section' : ''}`}>
      <div class="cs-section-inner">
        <SectionHeader
          number={section.number}
          title={section.heading}
          dark={section.variant === 'dark'}
        />

        {section.blocks ? (
          section.blocks.map((block: any) => (
            <Fragment>
              {block.heading && block.showHeading !== false && (
                <h3
                  id={block.showInNav ? `block-${block.heading.toLowerCase().replace(/[^a-z0-9]+/g, '-')}` : undefined}
                  class={`cs-block-heading reveal ${section.variant === 'dark' ? 'cs-block-heading--dark' : ''} ${block.heading?.includes('3+ New') ? 'cs-block-heading--wide' : ''}`}
                >
                  {block.heading}
                </h3>
              )}
              {block.heading && block.showHeading === false && block.showInNav && (
                <span id={`block-${block.heading.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} />
              )}
              {block.body && (
                <div
                  class={`cs-body-text reveal ${section.variant === 'dark' ? 'cs-body-text--dark' : ''} ${!block.media || block.media.length === 0 ? 'cs-body-text--wide' : ''}`}
                  set:html={block.body}
                />
              )}
              {block.media?.map((m: any) => (
                <MediaBlock
                  variant={m.variant}
                  images={m.images ?? []}
                  text={m.text}
                  dark={section.variant === 'dark'}
                  reversed={m.reversed ?? false}
                />
              ))}
            </Fragment>
          ))
        ) : (
          <Fragment>
            <div
              class={`cs-body-text reveal ${section.variant === 'dark' ? 'cs-body-text--dark' : ''}`}
              set:html={section.body}
            />
            {section.media?.map((block: any) => (
              <MediaBlock
                variant={block.variant}
                images={block.images ?? []}
                text={block.text}
                dark={section.variant === 'dark'}
              />
            ))}
          </Fragment>
        )}
      </div>
    </section>
  ))}

  <!-- Metrics -->
  {project.metrics?.length > 0 && (
    <StatRow metrics={project.metrics} />
  )}

  <!-- Testimonials -->
  {project.testimonials?.length > 0 && (
    <TestimonialStrip testimonials={project.testimonials} />
  )}

  <!-- Next project nav -->
  <div class="cs-footer section-pad--sm">
    <div class="container">
      <a href="/portfolio" class="btn btn--ghost">← Back to all work</a>
    </div>
  </div>
</BaseLayout>

<style>
  /* Header */
  .cs-header {
    padding-top: calc(64px + var(--space-7));
    padding-bottom: 0;
    background: var(--color-bg);
  }

  .cs-header-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-4);
    padding-bottom: var(--space-6);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    transition: color var(--duration-fast);
  }

  .back-link:hover { color: var(--color-text); }

  .cs-meta {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .cs-date { margin-left: auto; }

  .cs-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-3xl), 5.5vw, var(--text-4xl));
    line-height: var(--leading-tight);
    letter-spacing: -0.025em;
    margin-bottom: var(--space-3);
    max-width: 20em;
  }

  .cs-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 100ch;
    line-height: var(--leading-loose);
  }

  .cs-details {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .cs-detail {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs-detail-label {
    color: var(--color-text-muted);
  }

  .cs-detail-value {
    font-size: var(--text-s);
    color: var(--color-text);
    font-weight: 500;
  }

  .cs-cover {
    width: 100%;
    overflow: hidden;
    background: var(--color-bg-card);
  }

  .cs-cover-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .cs-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(160deg, var(--color-bg-card) 0%, var(--color-border) 100%);
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 5rem);
    font-style: italic;
    color: rgba(26,26,24,0.06);
  }

  /* Sections */
  /* Default: tighter spacing between same-variant sections */
  .cs-section {
    padding: var(--space-3) var(--space-4);
  }

  /* First section after the header gets more breathing room */
  .cs-section:first-of-type {
    padding-top: var(--space-7);
  }

  /* Dark sections get generous breathing room */
  .dark-section {
    padding-top: var(--space-7);
    padding-bottom: var(--space-1);
  }

  .dark-section + .dark-section {
    padding-top: var(--space-6);
  }

  /* Variant change light → dark (before section 03) */
  .cs-section + .dark-section {
    padding-top: var(--space-7);
  }

  /* Variant change dark → light (if ever used) */
  .dark-section + .cs-section:not(.dark-section) {
    padding-top: var(--space-7);
  }

  /* Body text in dark sections: slightly larger, more breathing room */
  .dark-section .cs-body-text {
    font-size: 1.25rem;
    max-width: 100ch;
    margin-bottom: var(--space-6);
  }

  .cs-section-inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .cs-body-text {
    font-size: 1.25rem;
    line-height: var(--leading-loose);
    color: var(--color-text);
    max-width: 100ch;
    margin-bottom: var(--space-5);
  }

  .cs-body-text--dark { color: var(--color-text-dark); }

  /* prose styles inside set:html */
  .cs-body-text :global(p) { margin-bottom: var(--space-3); }
  .cs-body-text :global(strong) { font-weight: 600; }

  .cs-block-heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    line-height: var(--leading-tight);
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-bottom: var(--space-3);
    margin-top: var(--space-6);
  }

  .cs-block-heading--dark { color: var(--color-text-dark); }

  /* First block heading in a section gets less top margin */
  .cs-section-inner > .cs-block-heading:first-child {
    margin-top: var(--space-5);
  }

  /* Hairline rule between sibling block headings in dark sections */
  .dark-section .cs-block-heading--dark ~ .cs-block-heading--dark {
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border-dark);
    margin-top: var(--space-7);
  }

  .cs-footer { background: var(--color-bg); }

  /* Wide text for specific blocks */
  .cs-body-text--wide {
    max-width: none !important;
    width: 100% !important;
  }

  /* Scroll nav */
  .scroll-nav {
    position: fixed;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    z-index: 50;
  }

  @media (max-width: 1100px) {
    .scroll-nav { display: none; }
  }

  .scroll-nav-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    background: var(--color-border);
    z-index: -1;
  }

  .scroll-nav-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    position: relative;
    z-index: 1;
  }

  .scroll-nav-block {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--color-border);
    transition: background var(--duration-fast), transform var(--duration-fast);
  }

  .scroll-nav-dot.active .scroll-nav-block {
    background: var(--color-accent);
    transform: scale(1.5);
  }
</style>

<script>
  // Scroll nav: highlight active section
  const navDots = document.querySelectorAll<HTMLElement>('[data-nav-id]');
  const navSections = Array.from(navDots).map(dot => ({
    dot,
    target: document.getElementById(dot.dataset.navId ?? '')
  })).filter(s => s.target);

  if (navSections.length > 0) {
    // Set first dot active initially
    navSections[0].dot.classList.add('active');

    const navObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = navSections.findIndex(s => s.target === entry.target);
          if (idx !== -1) {
            navDots.forEach(d => d.classList.remove('active'));
            navSections[idx].dot.classList.add('active');
          }
        }
      });
    }, { threshold: 0, rootMargin: '-10% 0px -50% 0px' });

    navSections.forEach(s => navObserver.observe(s.target!));

    // Smooth scroll on click
    navDots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById(dot.dataset.navId ?? '')?.scrollIntoView({ behavior: 'smooth' });
      });
    });
  }
</script>
