---
interface Testimonial {
  type: 'quote' | 'screenshot';
  quote?: string;
  speaker?: string;
  title?: string;
  company?: string;
  image?: string;
  alt?: string;
  caption?: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<div class="strip-wrap">
  <div class="strip-label-row">
    <span class="strip-label label">Speaker Testimonials</span>
  </div>
  <div class="strip" id="testimonial-strip">
    {testimonials.map((t) => (
      <div class="strip-item">
        {t.type === 'screenshot' && t.image ? (
          <div class="strip-screenshot">
            <img src={t.image} alt={t.alt ?? ''} loading="lazy" />
            {t.caption && <p class="strip-caption label">{t.caption}</p>}
          </div>
        ) : (
          <div class="strip-quote">
            <blockquote class="strip-quote-text">"{t.quote}"</blockquote>
            <div class="strip-attribution">
              <span class="strip-speaker">{t.speaker}</span>
              {t.title && t.company && (
                <span class="strip-role label">{t.title}, {t.company}</span>
              )}
            </div>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<script>
  const strip = document.getElementById('testimonial-strip');
  if (strip) {
    let paused = false;
    let isDragging = false;
    let startX = 0;
    let startScroll = 0;

    // Drag to scroll
    strip.addEventListener('mousedown', (e) => {
      isDragging = true;
      paused = true;
      strip.classList.add('dragging');
      startX = e.pageX;
      startScroll = strip.scrollLeft;
    });
    window.addEventListener('mouseup', () => {
      isDragging = false;
      paused = false;
      strip.classList.remove('dragging');
    });
    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      e.preventDefault();
      strip.scrollLeft = startScroll - (e.pageX - startX) * 1.5;
    });

    // Pause on hover
    strip.addEventListener('mouseenter', () => { if (!isDragging) paused = true; });
    strip.addEventListener('mouseleave', () => { if (!isDragging) paused = false; });

    // rAF auto-scroll
    let pos = 0;
    function tick() {
      if (!paused) {
        pos += 0.6;
        if (pos >= strip.scrollWidth - strip.clientWidth) pos = 0;
        strip.scrollLeft = pos;
      } else {
        pos = strip.scrollLeft;
      }
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
</script>

<style>
  .strip-wrap {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    background: var(--color-bg-dark);
    padding-top: var(--space-5);
    padding-bottom: var(--space-6);
    overflow: hidden;
  }

  .strip-label-row {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .strip-label {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-dark-muted);
  }

  .strip {
    display: flex;
    gap: var(--space-3);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-inline: var(--space-5);
    cursor: grab;
    user-select: none;
  }

  .strip.dragging { cursor: grabbing; }
  .strip::-webkit-scrollbar { display: none; }

  .strip-item {
    flex-shrink: 0;
    width: clamp(260px, 30vw, 400px);
  }

  .strip-screenshot img {
    width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-dark);
  }

  .strip-caption {
    margin-top: var(--space-1);
    color: var(--color-text-dark-muted);
  }

  .strip-quote {
    background: var(--color-bg-card-dark);
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .strip-quote-text {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-style: italic;
    line-height: 2;
    color: var(--color-text-dark);
  }

  .strip-attribution {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .strip-speaker {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-dark);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .strip-role {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-dark-muted);
    letter-spacing: var(--tracking-wide);
  }
</style>
