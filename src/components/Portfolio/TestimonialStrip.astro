---
interface Testimonial {
  type: 'quote' | 'screenshot';
  quote?: string;
  speaker?: string;
  title?: string;
  company?: string;
  image?: string;
  alt?: string;
  caption?: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<div class="strip-wrap">
  <div class="strip" id="testimonial-strip">
    {testimonials.map((t) => (
      <div class="strip-item">
        {t.type === 'screenshot' && t.image ? (
          <div class="strip-screenshot">
            <img src={t.image} alt={t.alt ?? ''} loading="lazy" />
            {t.caption && <p class="strip-caption label">{t.caption}</p>}
          </div>
        ) : (
          <div class="strip-quote">
            <blockquote class="strip-quote-text">"{t.quote}"</blockquote>
            <div class="strip-attribution">
              <span class="strip-speaker">{t.speaker}</span>
              {t.title && t.company && (
                <span class="strip-role label">{t.title}, {t.company}</span>
              )}
            </div>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<script>
  const strip = document.getElementById('testimonial-strip');
  if (strip) {
    // Drag to scroll
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;

    strip.addEventListener('mousedown', (e) => {
      isDown = true;
      strip.classList.add('dragging');
      startX = e.pageX - strip.offsetLeft;
      scrollLeft = strip.scrollLeft;
    });

    strip.addEventListener('mouseleave', () => { isDown = false; strip.classList.remove('dragging'); });
    strip.addEventListener('mouseup', () => { isDown = false; strip.classList.remove('dragging'); });
    strip.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - strip.offsetLeft;
      const walk = (x - startX) * 1.5;
      strip.scrollLeft = scrollLeft - walk;
    });

    // Slow auto-scroll on desktop, paused on hover
    let autoScroll: number | undefined;
    const startAutoScroll = () => {
      autoScroll = window.setInterval(() => {
        if (strip.scrollLeft + strip.clientWidth >= strip.scrollWidth - 2) {
          strip.scrollLeft = 0;
        } else {
          strip.scrollLeft += 0.6;
        }
      }, 16);
    };

    if (window.matchMedia('(min-width: 768px)').matches) {
      startAutoScroll();
      strip.addEventListener('mouseenter', () => clearInterval(autoScroll));
      strip.addEventListener('mouseleave', startAutoScroll);
    }
  }
</script>

<style>
  .strip-wrap {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    background: var(--color-bg-dark);
    padding-block: var(--space-6);
    overflow: hidden;
  }

  .strip {
    display: flex;
    gap: var(--space-3);
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-inline: var(--space-5);
    cursor: grab;
    user-select: none;
  }

  .strip.dragging { cursor: grabbing; }
  .strip::-webkit-scrollbar { display: none; }

  .strip-item {
    flex-shrink: 0;
    width: clamp(260px, 30vw, 400px);
  }

  .strip-screenshot img {
    width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-dark);
  }

  .strip-caption {
    margin-top: var(--space-1);
    color: var(--color-text-dark-muted);
  }

  .strip-quote {
    background: var(--color-bg-card-dark);
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .strip-quote-text {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-style: italic;
    line-height: var(--leading-normal);
    color: var(--color-text-dark);
  }

  .strip-attribution {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .strip-speaker {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text-dark);
  }

  .strip-role {
    color: var(--color-text-dark-muted);
  }
</style>
