---
interface Props {
  quote: string;
  attribution?: string;
  dark?: boolean;
}

const { quote, attribution, dark = false } = Astro.props;
---

<aside class={`pull-quote reveal ${dark ? 'pull-quote--dark' : ''}`}>
  <span class="pull-quote-mark" aria-hidden="true">"</span>
  <blockquote class="pull-quote-text">{quote}</blockquote>
  {attribution && <cite class="pull-quote-cite label">{attribution}</cite>}
</aside>

<style>
  .pull-quote {
    position: relative;
    padding: var(--space-5) var(--space-5) var(--space-5) var(--space-6);
    border-left: 3px solid var(--color-accent);
    margin-block: var(--space-6);
  }

  .pull-quote-mark {
    position: absolute;
    top: -8px;
    left: var(--space-3);
    font-family: var(--font-heading);
    font-size: 6rem;
    line-height: 1;
    color: var(--color-accent);
    opacity: 0.15;
    pointer-events: none;
  }

  .pull-quote-text {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-2xl));
    font-style: italic;
    line-height: var(--leading-normal);
    color: var(--color-text);
    max-width: 44ch;
  }

  .pull-quote--dark .pull-quote-text {
    color: var(--color-text-dark);
  }

  .pull-quote-cite {
    display: block;
    margin-top: var(--space-2);
    color: var(--color-text-muted);
  }

  .pull-quote--dark .pull-quote-cite {
    color: var(--color-text-dark-muted);
  }
</style>
