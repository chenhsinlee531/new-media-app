<footer class="site-footer">
  <div class="footer-inner">
    <span class="footer-name">ChenHsin Lee</span>
    <div class="footer-links">
      <a href="https://www.linkedin.com/in/chen-hsin-lee/" target="_blank" rel="noopener" class="footer-link">LinkedIn</a>
      <span class="sep" aria-hidden="true">·</span>
      <a href="mailto:chenhsin.lee.531@gmail.com" class="footer-link">Email</a>
    </div>
    <span class="footer-copy">© 2026</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-4);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--space-4);
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .footer-name {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-text);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer-link {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color var(--duration-fast);
  }

  .footer-link:hover { color: var(--color-text); }

  .sep { color: var(--color-border); }

  .footer-copy {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
  }
</style>
